<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 FFmpeg GUI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_output_dir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Output: ..."
            android:textSize="11sp"
            android:textColor="#888888"
            android:paddingBottom="12dp" />

        <!-- File Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📁 INPUT FILE"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/btn_pick_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pick Video / Audio File"
                    android:backgroundTint="#3700B3" />

                <TextView
                    android:id="@+id/tv_selected_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file selected"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:paddingTop="8dp" />

                <Button
                    android:id="@+id/btn_probe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔍 Probe Media Info"
                    android:backgroundTint="#018786"
                    android:layout_marginTop="8dp"
                    android:enabled="false" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Operations Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ OPERATIONS"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btn_convert_mp4"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="▶ To MP4"
                        android:backgroundTint="#6200EE"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btn_extract_audio"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🎵 Audio"
                        android:backgroundTint="#6200EE"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <Button
                    android:id="@+id/btn_compress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📦 Compress Video (720p CRF28)"
                    android:backgroundTint="#6200EE"
                    android:layout_marginBottom="8dp" />

                <!-- Trim Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✂️ Trim (seconds)"
                    android:textColor="#BBBBBB"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Start (s)"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_trim_start"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"
                            android:text="0" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="End (s)"
                        android:layout_marginStart="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_trim_end"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"
                            android:text="30" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btn_trim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✂️ Trim Video"
                    android:backgroundTint="#6200EE" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Custom Command Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💻 CUSTOM FFMPEG COMMAND"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Use {input} and {output_dir} as placeholders"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. -i {input} -vf scale=480:-1 {output_dir}/out.mp4"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_custom_command"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:gravity="top"
                        android:textColor="#FFFFFF"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_run_custom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ Run Custom Command"
                    android:backgroundTint="#018786"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 PROGRESS"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#BB86FC" />

                <TextView
                    android:id="@+id/tv_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready."
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:paddingTop="6dp"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏹ Cancel Operation"
                    android:backgroundTint="#CF6679"
                    android:enabled="false"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Log Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="📋 FFmpeg LOG"
                        android:textColor="#BB86FC"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textSize="11sp"
                        android:backgroundTint="#333333" />

                </LinearLayout>

                <ScrollView
                    android:id="@+id/scroll_log"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="8dp"
                    android:background="#0A0A0A"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#00FF88"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.2" />

                </ScrollView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
